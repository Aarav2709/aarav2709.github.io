---
const SERVICE_ID = import.meta.env.PUBLIC_EMAILJS_SERVICE_ID ?? null;
const PUBLIC_KEY = import.meta.env.PUBLIC_EMAILJS_PUBLIC_KEY ?? null;
const OWNER_TEMPLATE_ID =
  import.meta.env.PUBLIC_EMAILJS_OWNER_TEMPLATE_ID ?? null;
const USER_TEMPLATE_ID =
  import.meta.env.PUBLIC_EMAILJS_USER_TEMPLATE_ID ?? null;
const TO_EMAIL =
  import.meta.env.PUBLIC_EMAILJS_TO_EMAIL ?? "tribejustice35@gmail.com";
---

<div class="contact-section">
  <div class="contact-info">
    <p>
      Open to collaboration, consulting, and interesting engineering problems.
      Reach out directly or use the form below.
    </p>
    <div class="contact-links">
      <a
        href="https://mail.google.com/mail/?view=cm&fs=1&to=tribejustice35@gmail.com&su=Portfolio%20Inquiry&body=Hi%20Aarav%2C%0A%0A"
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>tribejustice35@gmail.com</span>
      </a>
      <a
        href="https://github.com/Aarav2709"
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>github.com/Aarav2709</span>
      </a>
      <a
        href="https://linkedin.com/in/aarav2709"
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>linkedin.com/in/aarav2709</span>
      </a>
    </div>
  </div>

  <form class="contact-form" id="contactForm">
    <div class="form-group">
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Your name"
        required
      />
    </div>
    <div class="form-group">
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Your email"
        required
      />
    </div>
    <div class="form-group">
      <textarea
        id="message"
        name="message"
        placeholder="Your message"
        rows="5"
        required></textarea>
    </div>
    <button type="submit" class="submit-button">
      <span class="button-text">send message</span>
    </button>
  </form>
</div>

<div id="notification" class="notification" style="display: none;"></div>

<div
  id="contactConfig"
  data-service-id={SERVICE_ID}
  data-public-key={PUBLIC_KEY}
  data-owner-template-id={OWNER_TEMPLATE_ID}
  data-user-template-id={USER_TEMPLATE_ID}
  data-to-email={TO_EMAIL}
  style="display:none;"
></div>

<script>
  import { initContactForm } from "../utils/contactFormClient";

  const cfg = document.getElementById("contactConfig");
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const notification = document.getElementById("notification");

  if (cfg && form) {
    initContactForm(form, notification, {
      serviceId: cfg.dataset.serviceId ?? null,
      publicKey: cfg.dataset.publicKey ?? null,
      ownerTemplateId: cfg.dataset.ownerTemplateId ?? null,
      userTemplateId: cfg.dataset.userTemplateId ?? null,
      toEmail: cfg.dataset.toEmail ?? "tribejustice35@gmail.com",
    });
  }
</script>

<style>
  .contact-section {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 1.4rem;
    margin-top: 1.25rem;
  }

  .contact-info,
  .contact-form {
    border: none;
    border-radius: 0;
    background: none;
  }

  .contact-info {
    padding: 0.25rem 0;
  }

  .contact-info p {
    font-size: var(--font-size-small);
    line-height: 1.75;
    margin-bottom: 1rem;
    color: var(--secondary-text);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none !important;
    color: #d2ddb1;
    font-weight: 500;
    padding: 0;
    border-radius: 0;
    transition: var(--transition-smooth);
    font-size: var(--font-size-small);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    background: none;
    border: none;
    width: fit-content;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.44);
  }

  .contact-link:hover {
    color: #e3f1be;
    border-bottom-color: rgba(181, 214, 145, 0.72);
    text-decoration: none !important;
    transform: translateX(3px);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0.2rem 0 0;
    border-top: 1px dashed rgba(167, 192, 128, 0.3);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 0;
    border: none;
    border-bottom: 1px solid rgba(167, 192, 128, 0.34);
    border-radius: 0;
    background: none;
    color: var(--primary-text);
    font-family: var(--font-family);
    font-size: var(--font-size-small);
    transition: var(--transition-smooth);
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: rgba(181, 214, 145, 0.62);
    box-shadow: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #9fb08d;
  }

  .submit-button {
    background: none;
    color: #d8e7b3;
    border: none;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.52);
    padding: 0.2rem 0;
    border-radius: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-small);
    letter-spacing: 0.05em;
    font-weight: 400;
    text-transform: lowercase;
    cursor: pointer;
    transition: var(--transition-smooth);
    align-self: flex-start;
  }

  .submit-button:hover {
    color: #ebf8c8;
    border-bottom-color: rgba(181, 214, 145, 0.72);
    transform: translateY(-1px);
  }

  .submit-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }

  .notification {
    position: fixed;
    top: 4.5rem;
    right: 1.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--rounded-corner);
    box-shadow: var(--shadow-raised);
    z-index: 10000;
    max-width: 400px;
    font-size: var(--font-size-small);
    line-height: 1.4;
    color: #f3f7ef;
    backdrop-filter: var(--blur);
  }

  .notification-success {
    background: rgba(104, 146, 94, 0.9);
    border: 1px solid rgba(190, 228, 169, 0.4);
  }

  .notification-error {
    background: rgba(178, 88, 93, 0.92);
    border: 1px solid rgba(234, 166, 170, 0.42);
  }

  @media (max-width: 768px) {
    .contact-section {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-info,
    .contact-form {
      padding: 0;
    }
  }
</style>
