---
const TO_EMAIL = "aaravgupta2709@proton.me";
---

<div class="contact-section">
  <div class="contact-info">
    <p>
      Open to collaboration, consulting, and interesting engineering problems.
      Reach out directly or use the form below.
    </p>
    <div class="contact-links">
      <a
        href={`https://mail.google.com/mail/?view=cm&fs=1&to=${TO_EMAIL}&su=Portfolio%20Inquiry&body=Hi%20Aarav%2C%0A%0A`}
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>aaravgupta2709@proton.me</span>
      </a>
      <a
        href="https://github.com/Aarav2709"
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>github.com/Aarav2709</span>
      </a>
      <a
        href="https://linkedin.com/in/aarav2709"
        class="contact-link"
        target="_blank"
        rel="noopener"
      >
        <span>linkedin.com/in/aarav2709</span>
      </a>
    </div>
  </div>

  <form class="contact-form" id="contactForm">
    <div class="form-group">
      <input
        type="text"
        id="name"
        name="name"
        placeholder="Your name"
        required
      />
    </div>
    <div class="form-group">
      <input
        type="email"
        id="email"
        name="email"
        placeholder="Your email"
        required
      />
    </div>
    <div class="form-group">
      <textarea
        id="message"
        name="message"
        placeholder="Your message"
        rows="5"
        required></textarea>
    </div>
    <button type="submit" class="submit-button">
      <span class="button-text">send message</span>
    </button>
  </form>
</div>

<div id="notification" class="notification" style="display: none;"></div>

<script define:vars={{ TO_EMAIL }}>
  const form = document.getElementById("contactForm");
  const notification = document.getElementById("notification");
  const toEmail = TO_EMAIL;

  const showNotification = (message, type) => {
    if (!notification) {
      return;
    }

    notification.textContent = message;
    notification.className = `notification notification-${type}`;
    notification.style.display = "block";

    window.setTimeout(() => {
      notification.style.display = "none";
    }, 3500);
  };

  if (form && form.dataset.gmailComposeBound !== "true") {
    form.dataset.gmailComposeBound = "true";
    let isSubmitting = false;

    form.addEventListener("submit", (event) => {
      event.preventDefault();

      if (isSubmitting) {
        return;
      }

      isSubmitting = true;
      const submitButton = form.querySelector(".submit-button");
      if (submitButton) {
        submitButton.disabled = true;
      }

      const formData = new FormData(form);
      const name = String(formData.get("name") ?? "").trim();
      const email = String(formData.get("email") ?? "").trim();
      const message = String(formData.get("message") ?? "").trim();

      if (!name || !email || !message) {
        showNotification("Please fill all fields before sending.", "error");
        isSubmitting = false;
        if (submitButton) {
          submitButton.disabled = false;
        }
        return;
      }

      const composedBody = `name: ${name}\nemail: ${email}\n\n${message}`;
      const gmailUrl = new URL("https://mail.google.com/mail/");
      gmailUrl.searchParams.set("view", "cm");
      gmailUrl.searchParams.set("fs", "1");
      gmailUrl.searchParams.set("to", toEmail);
      gmailUrl.searchParams.set("su", "Hello");
      gmailUrl.searchParams.set("body", composedBody);

      window.open(gmailUrl.toString(), "_blank", "noopener,noreferrer");

      showNotification("Success. Opened Gmail compose in one new tab.", "success");
      form.reset();

      window.setTimeout(() => {
        isSubmitting = false;
        if (submitButton) {
          submitButton.disabled = false;
        }
      }, 350);
    });
  }
</script>

<style>
  .contact-section {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 1.4rem;
    margin-top: 1.25rem;
  }

  .contact-info,
  .contact-form {
    border: none;
    border-radius: 0;
    background: none;
  }

  .contact-info {
    padding: 0.25rem 0;
  }

  .contact-info p {
    font-size: var(--font-size-small);
    line-height: 1.75;
    margin-bottom: 1rem;
    color: var(--secondary-text);
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none !important;
    color: #d2ddb1;
    font-weight: 500;
    padding: 0;
    border-radius: 0;
    transition: var(--transition-smooth);
    font-size: var(--font-size-small);
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    text-transform: lowercase;
    background: none;
    border: none;
    width: fit-content;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.44);
  }

  .contact-link:hover {
    color: #e3f1be;
    border-bottom-color: rgba(181, 214, 145, 0.72);
    text-decoration: none !important;
    transform: translateX(3px);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0.2rem 0 0;
    border-top: 1px dashed rgba(167, 192, 128, 0.3);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 0;
    border: none;
    border-bottom: 1px solid rgba(167, 192, 128, 0.34);
    border-radius: 0;
    background: none;
    color: var(--primary-text);
    font-family: var(--font-family);
    font-size: var(--font-size-small);
    transition: var(--transition-smooth);
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: rgba(181, 214, 145, 0.62);
    box-shadow: none;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: #9fb08d;
  }

  .submit-button {
    background: none;
    color: #d8e7b3;
    border: none;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.52);
    padding: 0.2rem 0;
    border-radius: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-small);
    letter-spacing: 0.05em;
    font-weight: 400;
    text-transform: lowercase;
    cursor: pointer;
    transition: var(--transition-smooth);
    align-self: flex-start;
  }

  .submit-button:hover {
    color: #ebf8c8;
    border-bottom-color: rgba(181, 214, 145, 0.72);
    transform: translateY(-1px);
  }

  .submit-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }

  .notification {
    position: fixed;
    top: 4.5rem;
    right: 1.5rem;
    padding: 0.75rem 1.25rem;
    border-radius: var(--rounded-corner);
    box-shadow: var(--shadow-raised);
    z-index: 10000;
    max-width: 400px;
    font-size: var(--font-size-small);
    line-height: 1.4;
    color: #f3f7ef;
    backdrop-filter: var(--blur);
  }

  .notification-success {
    background: rgba(104, 146, 94, 0.9);
    border: 1px solid rgba(190, 228, 169, 0.4);
  }

  .notification-error {
    background: rgba(178, 88, 93, 0.92);
    border: 1px solid rgba(234, 166, 170, 0.42);
  }

  @media (max-width: 768px) {
    .contact-section {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-info,
    .contact-form {
      padding: 0;
    }
  }
</style>
