---
interface Props {
  title: string;
  description: string;
  tech: string[];
  github?: string;
  live?: string;
  stars?: number;
  index: number;
}

const { title, description, tech, github, live, stars, index } = Astro.props;
---

<div class="flagship slide-up" style={`animation-delay: ${index * 0.15}s`}>
  <div class="flagship-header">
    <span class="flagship-label">Featured</span>
    {
      github && (
        <span
          class="star-badge"
          data-github={github}
          data-stars={stars ?? 0}
          data-role="star-badge"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 .587l3.668 7.431L23.4 9.75l-5.7 5.556L19.335 24 12 19.897 4.665 24l1.634-8.694L.6 9.75l7.732-1.732z" />
          </svg>
          <span class="star-count">{stars ?? 0}</span>
        </span>
      )
    }
  </div>

  <h3 class="flagship-title">{title}</h3>
  <p class="flagship-description">{description}</p>

  <div class="flagship-tech">
    {tech.map((t: string) => <span class="tech-tag">{t}</span>)}
  </div>

  <div class="flagship-links">
    {
      github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="flagship-link">
          View source
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      )
    }
    {
      live && (
        <a href={live} target="_blank" rel="noopener noreferrer" class="flagship-link">
          Live
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M7 17L17 7M17 7H7M17 7v10" />
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  .flagship {
    padding: 0.85rem 0 1rem 0.9rem;
    border-top: none;
    border-left: 1px dashed rgba(167, 192, 128, 0.36);
    border-radius: 0;
    background: none;
    box-shadow: none;
    transition: var(--transition-smooth);
    position: relative;
    overflow: visible;
  }

  .flagship:hover {
    border-left-color: rgba(181, 214, 145, 0.72);
    transform: translateX(3px);
  }

  .flagship-header {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.05rem;
  }

  .flagship-label {
    font-family: var(--font-display);
    font-size: var(--font-size-xs);
    font-weight: 400;
    color: #deefb8;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0;
    border-radius: 0;
    background: none;
    border: none;
  }

  .flagship-title {
    position: relative;
    z-index: 1;
    font-size: 2.15rem;
    font-weight: 400;
    color: #dbe6b5;
    letter-spacing: 0.03em;
    line-height: 1.2;
    margin-bottom: 0.7rem;
    font-family: var(--font-display);
  }

  .flagship-description {
    position: relative;
    z-index: 1;
    color: var(--tertiary-text);
    font-size: var(--font-size-small);
    line-height: 1.72;
    margin-bottom: 1.15rem;
    max-width: 36rem;
  }

  .flagship-tech {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-bottom: 1.2rem;
  }

  .tech-tag {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 500;
    color: #b9ca9f;
    padding: 0;
    border: none;
    border-radius: 0;
    background: none;
    text-transform: lowercase;
    position: relative;
    padding-left: 0.7rem;
  }

  .tech-tag::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 0.34rem;
    height: 0.08rem;
    background: rgba(167, 192, 128, 0.62);
  }

  .flagship-links {
    position: relative;
    z-index: 1;
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
  }

  .flagship-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #d5dfad;
    font-size: var(--font-size-small);
    font-weight: 400;
    font-family: var(--font-display);
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: lowercase;
    padding: 0;
    border-radius: 0;
    border: none;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.45);
    background: none;
    transition: var(--transition-smooth);
  }

  .flagship-link:hover {
    color: #e3f1bf;
    border-bottom-color: rgba(181, 214, 145, 0.72);
    opacity: 1;
    text-decoration: none;
    transform: translateY(-1px);
  }

  .star-badge {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #c8d8aa;
    font-size: var(--font-size-xs);
    font-weight: 500;
    font-family: var(--font-mono);
    padding: 0;
    border-radius: 0;
    border: none;
    background: none;
  }

  .star-badge svg {
    width: 0.7rem;
    height: 0.7rem;
    fill: #dfefb6;
  }

  @media (max-width: 768px) {
    .flagship {
      padding: 0.75rem 0 0.95rem 0.75rem;
    }

    .flagship-title {
      font-size: 1.8rem;
    }
  }
</style>
