---
interface Props {
  title: string;
  number: string;
}

const { title, number } = Astro.props;
---

<div class="section-header">
  <span class="section-number">{number}</span>
  <h2 class="section-title">{title}</h2>
</div>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: flex-start;
    width: 100%;
    gap: 0.8rem;
    padding: 0.15rem 0 0.95rem;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.32);
    margin-bottom: 1.4rem;
  }

  .section-title {
    font-size: var(--section-size);
    font-weight: 400;
    margin: 0;
    color: #d9deb6;
    letter-spacing: 0.03em;
    text-transform: lowercase;
    line-height: 1.2;
    font-family: var(--font-display);
    text-shadow: none;
  }

  .section-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: auto;
    height: auto;
    padding: 0;
    border-radius: 0;
    border: none;
    background: none;
    font-family: var(--font-family);
    font-size: 0.92rem;
    color: #d8ecb8;
    font-weight: 700;
    letter-spacing: 0.04em;
    white-space: nowrap;
    flex-shrink: 0;
    transform: none;
    text-shadow: none;
  }

  @media (max-width: 768px) {
    .section-header {
      padding: 0 0 1rem;
      margin-bottom: 1.5rem;
    }
  }
</style>
