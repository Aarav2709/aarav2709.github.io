---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactForm from "../components/ContactForm.astro";
import { getCollection } from "astro:content";
import {
  getGitHubContributions,
  getGitHubStars,
  type GitHubContribution,
} from "../utils/github";

const allProjects = await getCollection("projects");
const projects = await Promise.all(
  allProjects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (project) => {
      if (project.data.github) {
        const stars = await getGitHubStars(project.data.github);
        return {
          ...project,
          data: {
            ...project.data,
            stars: stars,
          },
        };
      }
      return project;
    }),
);

const stackItems = [
  { name: "TypeScript", icon: "typescript" },
  { name: "Python", icon: "python" },
  { name: "Go", icon: "go" },
  { name: "Lua", icon: "lua" },
  { name: "C", icon: "c" },
  { name: "React", icon: "react" },
  { name: "Astro", icon: "astro" },
  { name: "Vite", icon: "vite" },
  { name: "FastAPI", icon: "fastapi" },
  { name: "Docker", icon: "docker" },
  { name: "GitHub Actions", icon: "githubactions" },
  { name: "Vercel", icon: "vercel" },
  { name: "Git", icon: "git" },
  { name: "CMake", icon: "cmake" },
  { name: "Rust", icon: "rust" },
  { name: "HTML/CSS", icon: "html5" },
];

const highlights = [
  {
    metric: "100k+",
    title: "Python and C Downloads",
    detail: "Combined downloads across my Python and C projects now crossing six figures.",
  },
  {
    metric: "500k+",
    title: "Website Visitors",
    detail: "Total visitors across my websites and shipped web projects.",
  },
  {
    metric: "CS50",
    title: "Harvard and MIT Certificate",
    detail: "Completed CS50 and earned the certificate.",
    certificate: {
      image: "/images/certs/CS50P.png",
      alt: "CS50 certificate",
    },
  },
  {
    metric: "Top 80",
    title: "IIT Roorkee Excellence",
    detail: "Certificate of Excellence after competing with 100k+ students for 80 seats in the IIT Roorkee 3D tour program.",
  },
  {
    metric: "Shaastra",
    title: "IIT Madras Qualification",
    detail: "Qualified both rounds in DSA, coding, maths, and reasoning.",
    certificate: {
      image: "/images/certs/IITM.png",
      alt: "Shaastra certificate",
    },
  },
  {
    metric: "4th + $200",
    title: "Lumi Hackathon",
    detail: "Placed 4th with HyprWeb and won $200 in project prizes.",
  },
];

const contributionUsername = "Aarav2709";
const contributions = await getGitHubContributions(contributionUsername);
const contributionPadding = contributions.length
  ? new Date(`${contributions[0].date}T00:00:00Z`).getUTCDay()
  : 0;
const contributionCells: Array<GitHubContribution | null> = [
  ...new Array(contributionPadding).fill(null),
  ...contributions,
];
const contributionTotal = contributions.reduce((sum, day) => sum + day.count, 0);
---

<Layout>
  <Header />

  <main>
    <section id="about" class="section fade-in">
      <div class="container">
        <SectionHeader title="about" number="01" />
        <div class="about-content">
          <p>
            I write software that ships. My work spans developer tooling,
            game engine internals, and web infrastructure. I build in Go,
            TypeScript, Python, and Lua, and I contribute to open source
            projects that people actually use.
          </p>
          <p>
            When I solve a problem, I publish the solution. When existing tools
            fall short, I build better ones. That approach has led to 100k+
            downloads, 500k+ website visitors, recognition across international hackathons, and a
            portfolio of tools used by developers worldwide.
          </p>
        </div>
      </div>
    </section>

    <section id="highlights" class="section fade-in">
      <div class="container">
        <SectionHeader title="highlights" number="02" />
        <div class="highlights-grid">
          {
            highlights.map((h, i) => (
              <div class="highlight-card slide-up" style={`animation-delay: ${i * 0.1}s`}>
                <div class="highlight-head">
                  <span class="highlight-metric">{h.metric}</span>
                </div>
                <h3 class="highlight-title">{h.title}</h3>
                <p class="highlight-detail">{h.detail}</p>
                {
                  h.certificate && (
                    <button
                      type="button"
                      class="highlight-link preview-trigger"
                      data-preview-open
                      data-preview-src={h.certificate.image}
                      data-preview-alt={h.certificate.alt}
                      data-preview-title={`${h.title} certificate`}
                      aria-label={`Open certificate for ${h.title}`}
                    >
                      view certificate
                    </button>
                  )
                }
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="section fade-in">
      <div class="container">
        <SectionHeader title="projects" number="03" />
        <div class="projects-grid">
          {
            projects.map((project, index) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                github={project.data.github}
                live={project.data.live}
                previewImage={project.data.previewImage}
                previewAlt={project.data.previewAlt}
                stars={project.data.stars}
                index={index}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="contact" class="section fade-in">
      <div class="container">
        <SectionHeader title="contact" number="04" />
        <ContactForm />
      </div>
    </section>

    <section id="skills" class="section fade-in">
      <div class="container">
        <SectionHeader title="stack" number="05" />
        <div class="stack-grid">
          {
            stackItems.map((item, si) => (
              <div class="stack-item slide-up" style={`animation-delay: ${si * 0.04}s`}>
                {
                  item.icon && (
                    <img
                      class="skill-logo"
                      src={`https://cdn.simpleicons.org/${item.icon}/a7c080`}
                      width="14"
                      height="14"
                      loading="lazy"
                      alt=""
                    />
                  )
                }
                <span class="skill-dash" aria-hidden="true"></span>
                <span class="skill-name">{item.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="commits" class="section fade-in">
      <div class="container">
        <SectionHeader title="commit graph" number="06" />
        {
          contributionCells.length > 0 ? (
            <div class="contribution-wrapper">
              <div
                class="contribution-grid"
                role="img"
                aria-label={`${contributionTotal} commits in the last year`}
              >
                {
                  contributionCells.map((day) => (
                    <span
                      class={`contribution-cell ${day ? `level-${Math.max(0, Math.min(4, day.level))}` : "level-empty"}`}
                      title={
                        day
                          ? `${day.date} - ${day.count} contribution${day.count === 1 ? "" : "s"}`
                          : ""
                      }
                    />
                  ))
                }
              </div>
              <div class="contribution-footer">
                <span>{contributionTotal} commits this year</span>
                <span class="commit-separator" aria-hidden="true"></span>
                <div class="contribution-legend" aria-hidden="true">
                  <span>less</span>
                  <span class="contribution-cell level-0"></span>
                  <span class="contribution-cell level-1"></span>
                  <span class="contribution-cell level-2"></span>
                  <span class="contribution-cell level-3"></span>
                  <span class="contribution-cell level-4"></span>
                  <span>more</span>
                </div>
              </div>
            </div>
          ) : (
            <p class="contribution-empty">Contribution graph is unavailable right now.</p>
          )
        }
      </div>
    </section>
  </main>

  <div id="preview-modal" class="preview-modal" hidden>
    <button
      type="button"
      class="preview-overlay"
      data-preview-close
      aria-label="Close image preview"
    />
    <div class="preview-dialog" role="dialog" aria-modal="true" aria-label="Image preview">
      <div class="preview-header">
        <p id="preview-modal-title" class="preview-title">Image preview</p>
        <button type="button" class="preview-close" data-preview-close aria-label="Close image preview">
          <span class="preview-close-icon" aria-hidden="true"></span>
        </button>
      </div>
      <img id="preview-modal-image" src="" alt="" loading="lazy" decoding="async" />
    </div>
  </div>

  <script is:inline>
    if (typeof window !== "undefined") {
      const CACHE_TTL = 1000 * 60 * 15;
      const STORAGE_KEY = "project-star-cache";

      const readCache = () => {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : {};
        } catch {
          return {};
        }
      };

      const writeCache = (cache) => {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(cache));
        } catch {}
      };

      const parseRepo = (githubUrl) => {
        try {
          const { pathname } = new URL(githubUrl);
          const parts = pathname.split("/").filter(Boolean);
          if (parts.length < 2) return null;
          return { owner: parts[0], repo: parts[1] };
        } catch {
          return null;
        }
      };

      const updateBadge = (badge, stars) => {
        const countEl = badge.querySelector(".star-count");
        badge.dataset.stars = String(stars);
        badge.setAttribute("aria-label", `${stars} stars`);
        if (countEl) countEl.textContent = String(stars);
      };

      const parseCompactNumber = (value) => {
        const normalized = String(value).trim().toLowerCase().replace(/,/g, "");
        if (!normalized) return null;
        if (normalized.endsWith("k")) {
          const base = Number.parseFloat(normalized.slice(0, -1));
          return Number.isFinite(base) ? Math.round(base * 1000) : null;
        }
        if (normalized.endsWith("m")) {
          const base = Number.parseFloat(normalized.slice(0, -1));
          return Number.isFinite(base) ? Math.round(base * 1000000) : null;
        }
        const parsed = Number.parseInt(normalized, 10);
        return Number.isFinite(parsed) ? parsed : null;
      };

      const fetchStarsFromShields = async (owner, repo) => {
        try {
          const res = await fetch(
            `https://img.shields.io/github/stars/${owner}/${repo}?style=social`,
          );
          if (!res.ok) return null;
          const svg = await res.text();
          const direct = svg.match(/id="rlink"[^>]*>\s*([^<]+)\s*<\/text>/i);
          if (direct?.[1]) {
            return parseCompactNumber(direct[1]);
          }
          return null;
        } catch {
          return null;
        }
      };

      const hydrateStars = async () => {
        const badges = Array.from(
          document.querySelectorAll('[data-role="star-badge"][data-github]'),
        );

        if (!badges.length) return;

        const cache = readCache();
        const now = Date.now();

        for (const badge of badges) {
          const github = badge.getAttribute("data-github");
          if (!github) continue;

          const cached = cache[github];
          if (cached && now - cached.ts < CACHE_TTL) {
            updateBadge(badge, cached.stars);
            continue;
          }

          const parsed = parseRepo(github);
          if (!parsed) continue;

          const stars = await fetchStarsFromShields(parsed.owner, parsed.repo);
          if (stars === null) continue;

          updateBadge(badge, stars);
          cache[github] = { stars, ts: now };
          writeCache(cache);
        }
      };

      if (document.readyState === "complete") {
        hydrateStars();
      } else {
        window.addEventListener("load", hydrateStars, { once: true });
      }

      const previewModal = document.getElementById("preview-modal");
      const previewImage = document.getElementById("preview-modal-image");
      const previewTitle = document.getElementById("preview-modal-title");

      const closePreviewModal = () => {
        if (!previewModal || !previewImage) return;
        previewModal.hidden = true;
        previewImage.setAttribute("src", "");
        previewImage.setAttribute("alt", "");
        if (previewTitle) {
          previewTitle.textContent = "Image preview";
        }
        document.body.classList.remove("preview-open");
      };

      const openPreviewModal = (src, alt, title) => {
        if (!previewModal || !previewImage || !src) return;
        previewImage.setAttribute("src", src);
        previewImage.setAttribute("alt", alt || "Image preview");
        if (previewTitle) {
          previewTitle.textContent = title || alt || "Image preview";
        }
        previewModal.hidden = false;
        document.body.classList.add("preview-open");
      };

      document.querySelectorAll("[data-preview-open]").forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();
          const source = event.currentTarget;
          if (!(source instanceof HTMLElement)) return;
          const src = source.getAttribute("data-preview-src");
          const alt = source.getAttribute("data-preview-alt");
          const title = source.getAttribute("data-preview-title");
          openPreviewModal(src, alt, title);
        });
      });

      document.querySelectorAll("[data-preview-close]").forEach((closeControl) => {
        closeControl.addEventListener("click", closePreviewModal);
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          closePreviewModal();
        }
      });
    }
  </script>
</Layout>

<style>
  .section {
    position: relative;
    padding: var(--section-padding);
  }

  .section .container {
    padding: 0;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    width: min(100%, 56rem);
    align-items: flex-start;
  }

  .about-content p {
    font-size: var(--font-size-small);
    line-height: 1.78;
    color: var(--secondary-text);
    max-width: 43rem;
    padding: 0;
    text-align: left;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.1rem;
    width: min(100%, 62rem);
  }

  .highlight-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(167, 192, 128, 0.24);
    border-radius: 0.8rem;
    background:
      linear-gradient(135deg, rgba(58, 69, 75, 0.44), rgba(42, 50, 55, 0.44)),
      radial-gradient(circle at top right, rgba(181, 214, 145, 0.12), transparent 50%);
    box-shadow: 0 10px 22px rgba(17, 23, 24, 0.36);
    transition: var(--transition-smooth);
    overflow: visible;
  }

  .highlight-card:hover {
    transform: translateY(-3px);
    border-color: rgba(181, 214, 145, 0.48);
    box-shadow: 0 18px 34px rgba(17, 23, 24, 0.48);
  }

  .highlight-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.65rem;
  }

  .highlight-metric {
    font-size: clamp(1.45rem, 2.8vw, 1.95rem);
    font-weight: 400;
    color: #e6f2c3;
    letter-spacing: 0.03em;
    line-height: 1.1;
    font-family: var(--font-display);
  }

  .highlight-title {
    margin: 0.1rem 0 0;
    font-size: var(--font-size-base);
    color: #d4dfb0;
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.34;
  }

  .highlight-detail {
    margin: 0;
    font-size: var(--font-size-xs);
    color: #8fa186;
    line-height: 1.58;
    font-weight: 500;
  }

  .highlight-link {
    margin-top: 0.2rem;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: #cde5a6;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    border-bottom: 1px dashed rgba(181, 214, 145, 0.5);
    border-top: none;
    border-left: none;
    border-right: none;
    background: none;
    appearance: none;
    padding: 0;
    cursor: pointer;
  }

  .highlight-link:hover {
    color: #ebf8c9;
    border-bottom-color: rgba(213, 239, 173, 0.75);
  }

  .preview-modal {
    position: fixed;
    inset: 0;
    z-index: 2200;
    display: grid;
    place-items: center;
    padding: 1rem;
  }

  .preview-modal[hidden] {
    display: none;
  }

  .preview-overlay {
    position: absolute;
    inset: 0;
    border: none;
    background: rgba(7, 10, 11, 0.76);
    cursor: pointer;
  }

  .preview-dialog {
    position: relative;
    z-index: 1;
    width: min(95vw, 62rem);
    max-height: 88vh;
    border-radius: 0.9rem;
    border: 1px solid rgba(181, 214, 145, 0.45);
    background: rgba(22, 29, 33, 0.97);
    padding: 0.75rem;
    box-shadow: 0 24px 44px rgba(0, 0, 0, 0.56);
  }

  .preview-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
    padding: 0.25rem 0.2rem 0.35rem;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.32);
  }

  .preview-title {
    margin: 0;
    color: #d4e5b8;
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.03em;
    line-height: 1.2;
  }

  .preview-dialog img {
    display: block;
    width: 100%;
    max-height: calc(88vh - 4rem);
    object-fit: contain;
    border-radius: 0.45rem;
    background: rgba(21, 27, 31, 0.82);
  }

  .preview-close {
    position: static;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    width: 2.05rem;
    height: 2.05rem;
    padding: 0;
    border-radius: 999px;
    border: 1px solid rgba(181, 214, 145, 0.48);
    background:
      radial-gradient(circle at 30% 24%, rgba(200, 231, 159, 0.2), transparent 58%),
      rgba(36, 45, 50, 0.96);
    color: #edf9d0;
    font-size: 0;
    line-height: 1;
    cursor: pointer;
    transition: var(--transition-smooth);
    box-shadow:
      0 8px 14px rgba(0, 0, 0, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .preview-close-icon {
    position: relative;
    width: 0.96rem;
    height: 0.96rem;
    color: currentColor;
  }

  .preview-close-icon::before,
  .preview-close-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0.95rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
  }

  .preview-close-icon::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .preview-close-icon::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .preview-close:hover {
    transform: translateY(-1px);
    border-color: rgba(220, 245, 183, 0.86);
    background:
      radial-gradient(circle at 30% 24%, rgba(220, 245, 183, 0.25), transparent 58%),
      rgba(58, 70, 76, 0.98);
    color: #ffffff;
  }

  .preview-close:focus-visible {
    outline: 2px solid rgba(220, 245, 183, 0.65);
    outline-offset: 2px;
  }

  .preview-close:active {
    transform: translateY(0);
  }

  :global(body.preview-open) {
    overflow: hidden;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.05rem;
    width: min(100%, 62rem);
  }

  .projects-grid :global(.project:first-child) {
    border-top: none;
  }

  .contribution-wrapper {
    margin-top: 0.2rem;
    width: min(100%, 62rem);
    margin-left: auto;
    margin-right: auto;
  }

  .contribution-grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 11px);
    grid-auto-columns: 11px;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    justify-content: center;
  }

  .contribution-grid::-webkit-scrollbar {
    display: none;
  }

  .contribution-cell {
    width: 11px;
    height: 11px;
    border-radius: 2px;
    border: 1px solid rgba(167, 192, 128, 0.14);
    background: rgba(64, 72, 76, 0.42);
  }

  .contribution-cell.level-empty,
  .contribution-cell.level-0 {
    background: rgba(58, 69, 74, 0.4);
  }

  .contribution-cell.level-1 {
    background: rgba(130, 163, 102, 0.45);
  }

  .contribution-cell.level-2 {
    background: rgba(140, 179, 106, 0.62);
  }

  .contribution-cell.level-3 {
    background: rgba(157, 200, 118, 0.74);
  }

  .contribution-cell.level-4 {
    background: rgba(178, 224, 137, 0.86);
  }

  .contribution-footer {
    margin-top: 0.45rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    justify-content: center;
    color: #a5b98f;
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
  }

  .contribution-legend {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    text-transform: lowercase;
  }

  .commit-separator {
    width: 1px;
    height: 0.85rem;
    background: rgba(167, 192, 128, 0.52);
    display: inline-block;
  }

  .contribution-empty {
    color: #82927c;
    font-size: var(--font-size-xs);
    margin-top: 0.5rem;
    font-family: var(--font-mono);
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.72rem;
    margin-top: 1rem;
    width: min(100%, 62rem);
    user-select: none;
    -webkit-user-select: none;
  }

  .stack-item {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.42rem;
    padding: 0.48rem 0;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.24);
    transition: var(--transition-smooth);
  }

  .skill-logo {
    width: 0.86rem;
    height: 0.86rem;
    opacity: 0.92;
    filter: saturate(0.88);
  }

  .skill-dash {
    width: 0.36rem;
    height: 0.08rem;
    background: rgba(167, 192, 128, 0.7);
    border-radius: 99px;
    transform: translateY(0.02rem);
  }

  .skill-name {
    font-size: var(--font-size-small);
    font-weight: 500;
    color: #b3c89a;
    font-family: var(--font-mono);
  }

  .stack-item:hover {
    color: #e1f0bd;
    transform: translateY(-1px);
  }

  .section .container :global(.contact-section) {
    width: min(100%, 62rem);
    margin-left: 0;
    margin-right: 0;
  }

  @media (max-width: 768px) {
    .section {
      padding: 2.8rem 0;
    }

    .section .container {
      padding: 0 var(--container-padding);
    }

    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .about-content p {
      font-size: var(--font-size-xs);
    }

    .about-content {
