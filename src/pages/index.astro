---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactForm from "../components/ContactForm.astro";
import { getCollection } from "astro:content";
import {
  getGitHubContributions,
  getGitHubStars,
  type GitHubContribution,
} from "../utils/github";

const allProjects = await getCollection("projects");
const projects = await Promise.all(
  allProjects
    .sort((a, b) => a.data.order - b.data.order)
    .map(async (project) => {
      if (project.data.github) {
        const stars = await getGitHubStars(project.data.github);
        return {
          ...project,
          data: {
            ...project.data,
            stars: stars,
          },
        };
      }
      return project;
    }),
);

const stackItems = [
  { name: "TypeScript", icon: "typescript" },
  { name: "Python", icon: "python" },
  { name: "Go", icon: "go" },
  { name: "Lua", icon: "lua" },
  { name: "C", icon: "c" },
  { name: "React", icon: "react" },
  { name: "Astro", icon: "astro" },
  { name: "Vite", icon: "vite" },
  { name: "FastAPI", icon: "fastapi" },
  { name: "Docker", icon: "docker" },
  { name: "GitHub Actions", icon: "githubactions" },
  { name: "Vercel", icon: "vercel" },
  { name: "Git", icon: "git" },
  { name: "CMake", icon: "cmake" },
  { name: "Solar2D" },
  { name: "HTML/CSS", icon: "html5" },
];

const highlights = [
  {
    metric: "50k+",
    label: "Downloads across Python and C projects.",
  },
  {
    metric: "100k+",
    label: "Visitors across live deployments.",
  },
  {
    metric: "10+",
    label: "Listed repos for minimalist design.",
  },
  {
    metric: "Top 80",
    label: "GambitoR 4.0 at IIT Roorkee out of 100k+ participants.",
  },
  {
    metric: "Shastra 2026",
    label: "Qualified both rounds at IIT Madras. DSA, coding, maths, and reasoning against school and college students.",
  },
  {
    metric: "3rd Global",
    label: "Won Lumi Hackathon. Placed 3rd globally and received $200 in cash prizes.",
  },
];

const building = [
  {
    name: "FR1: Reborn",
    description: "Racing remake focused on cleaner netcode and tighter multiplayer loops.",
    status: "active",
  },
  {
    name: "FR2: Replayed",
    description: "Second-entry rebuild with modernized systems, syncing, and progression.",
    status: "active",
  },
  {
    name: "SpankLaptop",
    description: "Fast terminal utility in Rust for quick diagnostics and system cleanup.",
    status: "active",
  },
];

const contributionUsername = "Aarav2709";
const contributions = await getGitHubContributions(contributionUsername);
const contributionPadding = contributions.length
  ? new Date(`${contributions[0].date}T00:00:00Z`).getUTCDay()
  : 0;
const contributionCells: Array<GitHubContribution | null> = [
  ...new Array(contributionPadding).fill(null),
  ...contributions,
];
const contributionTotal = contributions.reduce((sum, day) => sum + day.count, 0);
---

<Layout>
  <Header />

  <main>
    <section id="about" class="section fade-in">
      <div class="container">
        <SectionHeader title="about" number="01" />
        <div class="about-content">
          <p>
            I write software that ships. My work spans developer tooling,
            game engine internals, and web infrastructure. I build in Go,
            TypeScript, Python, and Lua, and I contribute to open source
            projects that people actually use.
          </p>
          <p>
            When I solve a problem, I publish the solution. When existing tools
            fall short, I build better ones. That approach has led to 50k+
            downloads, recognition across international hackathons, and a
            portfolio of tools used by developers worldwide.
          </p>
        </div>
      </div>
    </section>

    <section id="highlights" class="section fade-in">
      <div class="container">
        <SectionHeader title="highlights" number="02" />
        <div class="highlights-grid">
          {
            highlights.map((h, i) => (
              <div class="highlight-card slide-up" style={`animation-delay: ${i * 0.1}s`}>
                <span class="highlight-metric">{h.metric}</span>
                <span class="highlight-label">{h.label}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects" class="section fade-in">
      <div class="container">
        <SectionHeader title="projects" number="03" />
        <div class="projects-grid">
          {
            projects.map((project, index) => (
              <ProjectCard
                title={project.data.title}
                description={project.data.description}
                tech={project.data.tech}
                github={project.data.github}
                live={project.data.live}
                stars={project.data.stars}
                index={index}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="commits" class="section fade-in">
      <div class="container">
        <SectionHeader title="commit graph" number="04" />
        {
          contributionCells.length > 0 ? (
            <div class="contribution-wrapper">
              <div
                class="contribution-grid"
                role="img"
                aria-label={`${contributionTotal} commits in the last year`}
              >
                {
                  contributionCells.map((day) => (
                    <span
                      class={`contribution-cell ${day ? `level-${Math.max(0, Math.min(4, day.level))}` : "level-empty"}`}
                      title={
                        day
                          ? `${day.date} - ${day.count} contribution${day.count === 1 ? "" : "s"}`
                          : ""
                      }
                    />
                  ))
                }
              </div>
              <div class="contribution-footer">
                <span>{contributionTotal} commits this year</span>
                <div class="contribution-legend" aria-hidden="true">
                  <span>less</span>
                  <span class="contribution-cell level-0"></span>
                  <span class="contribution-cell level-1"></span>
                  <span class="contribution-cell level-2"></span>
                  <span class="contribution-cell level-3"></span>
                  <span class="contribution-cell level-4"></span>
                  <span>more</span>
                </div>
              </div>
            </div>
          ) : (
            <p class="contribution-empty">Contribution graph is unavailable right now.</p>
          )
        }
      </div>
    </section>

    <section id="skills" class="section fade-in">
      <div class="container">
        <SectionHeader title="stack" number="05" />
        <div class="stack-grid">
          {
            stackItems.map((item, si) => (
              <div class="stack-item slide-up" style={`animation-delay: ${si * 0.04}s`}>
                {
                  item.icon && (
                    <img
                      class="skill-logo"
                      src={`https://cdn.simpleicons.org/${item.icon}/a7c080`}
                      width="14"
                      height="14"
                      loading="lazy"
                      alt=""
                    />
                  )
                }
                <span class="skill-dash" aria-hidden="true"></span>
                <span class="skill-name">{item.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="building" class="section fade-in">
      <div class="container">
        <SectionHeader title="currently building" number="06" />
        <div class="building-list">
          {
            building.map((item, i) => (
              <div class="building-item slide-up" style={`animation-delay: ${i * 0.1}s`}>
                <div class="building-status">
                  <span class="status-dot" />
                </div>
                <div class="building-info">
                  <span class="building-name">{item.name}</span>
                  <span class="building-desc">{item.description}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="contact" class="section fade-in">
      <div class="container">
        <SectionHeader title="contact" number="07" />
        <ContactForm />
      </div>
    </section>
  </main>

  <script is:inline>
    if (typeof window !== "undefined") {
      const CACHE_TTL = 1000 * 60 * 15;
      const STORAGE_KEY = "project-star-cache";

      const readCache = () => {
        try {
          const raw = localStorage.getItem(STORAGE_KEY);
          return raw ? JSON.parse(raw) : {};
        } catch {
          return {};
        }
      };

      const writeCache = (cache) => {
        try {
          localStorage.setItem(STORAGE_KEY, JSON.stringify(cache));
        } catch {}
      };

      const parseRepo = (githubUrl) => {
        try {
          const { pathname } = new URL(githubUrl);
          const parts = pathname.split("/").filter(Boolean);
          if (parts.length < 2) return null;
          return { owner: parts[0], repo: parts[1] };
        } catch {
          return null;
        }
      };

      const updateBadge = (badge, stars) => {
        const countEl = badge.querySelector(".star-count");
        badge.dataset.stars = String(stars);
        badge.setAttribute("aria-label", `${stars} stars`);
        if (countEl) countEl.textContent = String(stars);
      };

      const parseCompactNumber = (value) => {
        const normalized = String(value).trim().toLowerCase().replace(/,/g, "");
        if (!normalized) return null;
        if (normalized.endsWith("k")) {
          const base = Number.parseFloat(normalized.slice(0, -1));
          return Number.isFinite(base) ? Math.round(base * 1000) : null;
        }
        if (normalized.endsWith("m")) {
          const base = Number.parseFloat(normalized.slice(0, -1));
          return Number.isFinite(base) ? Math.round(base * 1000000) : null;
        }
        const parsed = Number.parseInt(normalized, 10);
        return Number.isFinite(parsed) ? parsed : null;
      };

      const fetchStarsFromShields = async (owner, repo) => {
        try {
          const res = await fetch(
            `https://img.shields.io/github/stars/${owner}/${repo}?style=social`,
          );
          if (!res.ok) return null;
          const svg = await res.text();
          const direct = svg.match(/id="rlink"[^>]*>\s*([^<]+)\s*<\/text>/i);
          if (direct?.[1]) {
            return parseCompactNumber(direct[1]);
          }
          return null;
        } catch {
          return null;
        }
      };

      const hydrateStars = async () => {
        const badges = Array.from(
          document.querySelectorAll('[data-role="star-badge"][data-github]'),
        );

        if (!badges.length) return;

        const cache = readCache();
        const now = Date.now();

        for (const badge of badges) {
          const github = badge.getAttribute("data-github");
          if (!github) continue;

          const cached = cache[github];
          if (cached && now - cached.ts < CACHE_TTL) {
            updateBadge(badge, cached.stars);
            continue;
          }

          const parsed = parseRepo(github);
          if (!parsed) continue;

          const stars = await fetchStarsFromShields(parsed.owner, parsed.repo);
          if (stars === null) continue;

          updateBadge(badge, stars);
          cache[github] = { stars, ts: now };
          writeCache(cache);
        }
      };

      if (document.readyState === "complete") {
        hydrateStars();
      } else {
        window.addEventListener("load", hydrateStars, { once: true });
      }
    }
  </script>
</Layout>

<style>
  .section {
    position: relative;
    padding: var(--section-padding);
  }

  .section .container {
    padding: 0;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    width: min(100%, 48rem);
    align-items: flex-start;
  }

  .about-content p {
    font-size: var(--font-size-small);
    line-height: 1.78;
    color: var(--tertiary-text);
    max-width: 43rem;
    padding: 0;
    text-align: left;
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 1.1rem;
    width: min(100%, 62rem);
  }

  .highlight-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    padding: 0.95rem 1rem;
    border: 1px solid rgba(167, 192, 128, 0.28);
    border-radius: 0.75rem;
    background: linear-gradient(145deg, rgba(55, 66, 72, 0.36), rgba(49, 59, 64, 0.3));
    box-shadow: var(--shadow);
    transition: var(--transition-smooth);
  }

  .highlight-card:hover {
    transform: translateY(-2px);
    border-color: rgba(181, 214, 145, 0.48);
    box-shadow: var(--shadow-raised);
  }

  .highlight-metric {
    font-size: 2rem;
    font-weight: 400;
    color: #dfeab9;
    letter-spacing: 0.03em;
    line-height: 1.1;
    font-family: var(--font-display);
  }

  .highlight-label {
    font-size: var(--font-size-xs);
    color: #7f8f7b;
    line-height: 1.52;
    font-weight: 500;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.05rem;
    width: min(100%, 62rem);
  }

  .projects-grid :global(.project:first-child) {
    border-top: none;
  }

  .contribution-wrapper {
    margin-top: 0.2rem;
    width: min(100%, 62rem);
    margin-left: auto;
    margin-right: auto;
  }

  .contribution-grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 11px);
    grid-auto-columns: 11px;
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 0.5rem;
    justify-content: center;
  }

  .contribution-grid::-webkit-scrollbar {
    display: none;
  }

  .contribution-cell {
    width: 11px;
    height: 11px;
    border-radius: 2px;
    border: 1px solid rgba(167, 192, 128, 0.14);
    background: rgba(64, 72, 76, 0.42);
  }

  .contribution-cell.level-empty,
  .contribution-cell.level-0 {
    background: rgba(58, 69, 74, 0.4);
  }

  .contribution-cell.level-1 {
    background: rgba(130, 163, 102, 0.45);
  }

  .contribution-cell.level-2 {
    background: rgba(140, 179, 106, 0.62);
  }

  .contribution-cell.level-3 {
    background: rgba(157, 200, 118, 0.74);
  }

  .contribution-cell.level-4 {
    background: rgba(178, 224, 137, 0.86);
  }

  .contribution-footer {
    margin-top: 0.45rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    align-items: center;
    justify-content: center;
    color: #8ea183;
    font-size: var(--font-size-xs);
    font-family: var(--font-mono);
  }

  .contribution-legend {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    text-transform: lowercase;
  }

  .contribution-empty {
    color: #82927c;
    font-size: var(--font-size-xs);
    margin-top: 0.5rem;
    font-family: var(--font-mono);
  }

  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.72rem;
    margin-top: 1rem;
    width: min(100%, 62rem);
  }

  .stack-item {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.42rem;
    padding: 0.48rem 0;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.24);
    transition: var(--transition-smooth);
  }

  .skill-logo {
    width: 0.86rem;
    height: 0.86rem;
    opacity: 0.92;
    filter: saturate(0.88);
  }

  .skill-dash {
    width: 0.36rem;
    height: 0.08rem;
    background: rgba(167, 192, 128, 0.7);
    border-radius: 99px;
    transform: translateY(0.02rem);
  }

  .skill-name {
    font-size: var(--font-size-small);
    font-weight: 500;
    color: #b3c89a;
    font-family: var(--font-mono);
  }

  .stack-item:hover {
    color: #e1f0bd;
    transform: translateY(-1px);
  }

  .building-list {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    margin-top: 1rem;
    width: min(100%, 48rem);
  }

  .building-item {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
    gap: 0.8rem;
    padding: 0.8rem 0;
    border-bottom: 1px dashed rgba(167, 192, 128, 0.3);
    transition: var(--transition-smooth);
    text-align: left;
  }

  .building-item:last-child {
    border-bottom: none;
  }

  .building-item:hover {
    transform: translateX(3px);
  }

  .building-status {
    padding-top: 0.35rem;
  }

  .status-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #c9e7a1;
    box-shadow: 0 0 12px rgba(201, 231, 161, 0.62);
    animation: pulse 2s ease-in-out infinite;
  }

  .building-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: flex-start;
  }

  .building-name {
    font-size: var(--font-size-base);
    font-weight: 400;
    color: #d7e2b1;
    letter-spacing: 0.03em;
    font-family: var(--font-display);
  }

  .building-desc {
    font-size: var(--font-size-small);
    color: #879783;
    line-height: 1.55;
    font-weight: 500;
  }

  .section .container :global(.contact-section) {
    width: min(100%, 62rem);
    margin-left: 0;
    margin-right: 0;
  }

  @media (max-width: 768px) {
    .section {
      padding: 2.8rem 0;
    }

    .section .container {
      padding: 0;
    }

    .highlights-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .about-content p {
      font-size: var(--font-size-xs);
    }

    .contribution-grid {
      grid-auto-columns: 10px;
      grid-template-rows: repeat(7, 10px);
      gap: 3px;
    }

    .stack-grid {
      grid-template-columns: 1fr;
      gap: 0.35rem;
    }

    .highlight-card,
    .building-item {
      padding: 0.72rem;
    }

    .building-item {
      padding: 0.72rem 0;
    }
  }
</style>
